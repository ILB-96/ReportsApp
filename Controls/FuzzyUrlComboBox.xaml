<UserControl x:Class="Reports.Controls.FuzzyUrlComboBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <ComboBox x:Name="Combo"
              IsEditable="True"
              IsTextSearchEnabled="True"
              StaysOpenOnEdit="True"
              ItemsSource="{Binding ItemsSource, ElementName=Root}"
              Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              PreviewMouseLeftButtonDown="Combo_PreviewMouseLeftButtonDown"
              GotKeyboardFocus="Combo_GotKeyboardFocus"/>
</UserControl>