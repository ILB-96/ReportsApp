<Page x:Class="Reports.Tabs.AgreementForm"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Reports.Controls"
             FlowDirection="RightToLeft"
             d:DesignHeight="400"
             d:DesignWidth="300"
             ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             mc:Ignorable="d"
             >
    <Grid Margin="5" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <controls:SegmentedToggleSwitch
            x:Name="TogglePanel"
            LeftText="אוטותל"
            RightText="גוטו"
            IsChecked="{Binding IsGoto, Mode=TwoWay}"
            HorizontalAlignment="Center"/>

        <!-- Card with form -->
       
        <ui:Card x:Name="RootForm"
                 Grid.Row="1"
                 Padding="20"
                 Margin="0,0,0,10"
                 Background="Transparent">
            <StackPanel Orientation="Vertical">

                <!-- Regular Text Fields -->
                <ui:TextBox x:Name="Name"
                            PlaceholderText="שם לקוח"
                            Margin="0,5"/>

                <ui:TextBox x:Name="Date"
                            PlaceholderText="תאריך"
                            Margin="0,5"/>

                <!-- Submit Button -->
                <ui:Button Content="צור הסכם לקוח"
                           x:Name="SubmitButton"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Stretch"
                           IsDefault="True"
                           Click="Submit_Click"
                           Appearance="Primary"
                           FontWeight="Bold"/>
            </StackPanel>
        </ui:Card>
        <controls:LoadingOverlay x:Name="Loading"
                                 Grid.Row="0"
                                 Grid.RowSpan="2"
                                 IsCancelable="False"
                                 MinimumShowTimeMilliseconds="250"/>
    </Grid>
</Page>
