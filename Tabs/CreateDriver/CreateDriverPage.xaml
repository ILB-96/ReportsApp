<Page x:Class="Reports.Tabs.CreateDriver.CreateDriverPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Reports.Controls"
             FlowDirection="RightToLeft"
             d:DesignHeight="900"
             d:DesignWidth="600"
             ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
             mc:Ignorable="d" d:DataContext="{d:DesignInstance }">
    <Grid Margin="5" VerticalAlignment="Top" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Card with form -->
        <ui:Card Grid.Row="1" Padding="20" Margin="0,0,0,10" Background="Transparent" Visibility="{Binding View.InputPanelVisibility}">
            <Grid Grid.IsSharedSizeScope="True" FlowDirection="RightToLeft">
                <Grid.ColumnDefinitions>
                    <!-- Pair #1 -->
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Regular Text Fields -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="לינק קייס:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <controls:FuzzyUrlComboBox Grid.Row="0" Grid.Column="1"
                                           x:Name="Url"
                                           ItemsSource="{Binding SyncStore.TabUrls}"
                                           Text="{Binding View.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                
                <!-- Submit Button -->
                <ui:Button Content="יצא" Grid.Row="2" Grid.Column="1"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Stretch"
                        IsDefault="True"
                        Click="Submit_Click"
                        MaxWidth="150"
                        Appearance="Primary"
                        FontWeight="Bold"/>
                <ui:Button x:Name="ClearExcelButton"
                           Grid.Row="2" Grid.Column="0"
                           Content="נקה שורות מאקסל"
                           Margin="0,20,0,0"
                           
                           HorizontalAlignment="Stretch"
                           Appearance="Info"
                           MaxWidth="150"
                           Background="#B91C1C"
                           MouseOverBackground="#DC2626"
                           PressedBackground="#991B1B"
                           Click="ClearExcelMenu_Click">

                    <ui:Button.ContextMenu>
                        <ContextMenu FlowDirection="RightToLeft"
                                     ItemsSource="{Binding ServiceTypes}">
                            <ContextMenu.ItemContainerStyle>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Header" Value="{Binding}" />
                                    <Setter Property="Tag" Value="{Binding}" />
                                    <EventSetter Event="Click" Handler="ClearExcel_Click" />
                                </Style>
                            </ContextMenu.ItemContainerStyle>
                        </ContextMenu>
                    </ui:Button.ContextMenu>
                </ui:Button>
            </Grid>
        </ui:Card>
        <ui:Card Grid.Row="1"
                 Padding="20"
                 Margin="0,0,0,10"
                 Background="Transparent"
                 Visibility="{Binding View.DataPanelVisibility}"
                 FlowDirection="RightToLeft">

            <!-- One grid = consistent alignment for all rows -->
            <Grid Grid.IsSharedSizeScope="True" FlowDirection="RightToLeft">
                <Grid.ColumnDefinitions>
                    <!-- Pair #1 -->
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label" />
                    <ColumnDefinition Width="*" />
                    <!-- Gap -->
                    <ColumnDefinition Width="20" />
                    <!-- Pair #2 -->
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Label" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Start/End date -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="תאריך התחלה:" VerticalAlignment="Center" Margin="0,5,8,0" />
                <ui:TextBox Grid.Row="0" Grid.Column="1"  Text="{Binding View.ReportStartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="תאריך סיום:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="0" Grid.Column="4" Text="{Binding View.ReportEndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <!-- Row 1: License/Reservation -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="לוחית רישוי:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="1" Grid.Column="1" Text="{Binding View.CarLicense, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <TextBlock Grid.Row="1" Grid.Column="3" Text="מספר הזמנה:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="1" Grid.Column="4" Text="{Binding View.ReservationNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <!-- Row 2: Report number / Full name -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="מספר דוח:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="2" Grid.Column="1" Text="{Binding View.ReportNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <TextBlock Grid.Row="2" Grid.Column="3" Text="שם מלא:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="2" Grid.Column="4" Text="{Binding View.AccountFullName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <!-- Row 3: ID / Driver license -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="תעודת זהות:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="3" Grid.Column="1" Text="{Binding View.DriverId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <TextBlock Grid.Row="3" Grid.Column="3" Text="רישיון נהיגה:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="3" Grid.Column="4" Text="{Binding View.DriverLicense, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <!-- Row 4: Email / Phone -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="אימייל:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="4" Grid.Column="1" Text="{Binding View.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <TextBlock Grid.Row="4" Grid.Column="3" Text="טלפון:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="4" Grid.Column="4" Text="{Binding View.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <!-- Row 5: Address / House -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="כתובת:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="5" Grid.Column="1" Text="{Binding View.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <TextBlock Grid.Row="5" Grid.Column="3" Text="מספר בית:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="5" Grid.Column="4" Text="{Binding View.House, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <!-- Row 6: City / Postal -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="עיר:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="6" Grid.Column="1" Text="{Binding View.City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <TextBlock Grid.Row="6" Grid.Column="3" Text="מיקוד:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="6" Grid.Column="4" Text="{Binding View.PostalCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>
                
                <TextBlock Grid.Row="7" Grid.Column="3" Text="קישור לדרכון:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="7" Grid.Column="4" Text="{Binding View.PassportLink, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="קישור לרישיון:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="7" Grid.Column="1" Text="{Binding View.LicenseLink, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>


                <TextBlock Grid.Row="8" Grid.Column="0" Text="תאריך יצירה:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <ui:TextBox Grid.Row="8" Grid.Column="1" Text="{Binding View.CreatedOn, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/>
                
                <TextBlock Grid.Row="8" Grid.Column="3" Text="סוג שירות:" VerticalAlignment="Center" Margin="0,5,8,0"/>
                <controls:FuzzyUrlComboBox Grid.Row="8" Grid.Column="4"
                                           ItemsSource="{Binding ServiceTypes}"
                                           Text="{Binding View.ServiceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <!-- <ui:TextBox Grid.Row="8" Grid.Column="4" x:Name="ServiceTypeBox" Margin="0,5,0,0" HorizontalAlignment="Stretch" TextAlignment="Right"/> -->
                <!-- Row 9: Button -->
                
                <ui:Button Grid.Row="9" Grid.Column="2" Grid.ColumnSpan="3"
                           Content="שלח נתונים"
                           Margin="4,20,0,0"
                           HorizontalAlignment="Stretch"
                           Appearance="Primary"
                           FontWeight="Bold"
                           MaxWidth="250"
                           Click="SendFinal_Click"/>
                <ui:Button Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                           Content="חזור"
                           Margin="4,20,0,0"
                           HorizontalAlignment="Stretch"
                           Appearance="Secondary"
                           Click="PreviousPage_Click"/>
            </Grid>
        </ui:Card>
        <controls:LoadingOverlay x:Name="Loading"
                                 Grid.Row="0"
                                 Grid.RowSpan="2"
                                 IsCancelable="False"
                                 MinimumShowTimeMilliseconds="250"/>
        <controls:OverlayBanner x:Name="Overlay" Grid.Row="0"
                                />

    </Grid>
</Page>
