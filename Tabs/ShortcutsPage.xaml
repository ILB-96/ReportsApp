
<Page x:Class="Reports.Tabs.ShortcutsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="clr-namespace:Reports.Controls"
      xmlns:shared="clr-namespace:Reports.Utilities"
      mc:Ignorable="d"
      FlowDirection="RightToLeft"
      Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    
    <!-- Outer padding via Border -->
    <Border Padding="16">
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            


            <!-- Header -->
            <Grid Margin="0,0,0,8" Grid.IsSharedSizeScope="True">

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="קישור:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

                    <controls:FuzzyUrlComboBox Grid.Column="1"
                                               x:Name="Url"
                                                    ItemsSource="{Binding TabsStore.TabUrls}"
                                                    Text="{Binding SelectedUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>

                <!-- שורת עוגיות -->
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="עוגיות:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"/>

                    <ui:TextBox x:Name="Cookies"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                Text="{x:Static shared:UserSettings.LastCookie}"
                                TextAlignment="Right"/>
                </Grid>

            </Grid>

            <!-- Content Card -->
            <ui:Card Grid.Row="1" Padding="8" IsEnabled="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <!-- Optional small hint row -->
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <ui:SymbolIcon Symbol="ClipboardCheckmark24" Margin="0,0,8,0"/>
                        <TextBlock Text="לחיצה אחת מעתיקה את התבנית ללוח" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Shortcuts grid -->
                    <UniformGrid Grid.Row="2" Columns="2">
                        <!-- GoTo: paid fine -->
                        <ui:Button  Appearance="Info"
                                   Tag="goto"
                                   FontWeight="SemiBold"
                                   Click="Paid_Click"
                                   Margin="0 6">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTaskAdd24" Margin="0,0,4,0"/>
                                <TextBlock Text="דוח שולם – גוטו"/>
                            </StackPanel>
                        </ui:Button>


                        <ui:Button Appearance="Info"
                                   Background="DarkOrange"
                                   Tag="autotel"
                                   FontWeight="SemiBold"
                                   MouseOverBackground="Orange"
                                   PressedBackground="#FFA65D"
                                   Click="Paid_Click">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTaskAdd24" Margin="0,0,4,0"/>
                                <TextBlock Text="דוח שולם – אוטותל"/>
                            </StackPanel>
                        </ui:Button>
                        <!-- transport_fine -->
                        <ui:Button Appearance="Info"
                                   Background="#0F766E"
                                   Tag="transport_fine"
                                   FontWeight="SemiBold"
                                   MouseOverBackground="#0D9488"
                                   PressedBackground="#14B8A6"
                                   Click="Copy_Template_Click"
                                   Margin="0 6">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTaskAdd24" Margin="0,0,4,0"/>
                                <TextBlock Text="הסבת תחב״צ"/>
                            </StackPanel>
                        </ui:Button>
                        
                        <ui:Button Appearance="Info"
                                   Background="#9333EA"
                                   Tag="transfer_process"
                                   FontWeight="SemiBold"
                                   MouseOverBackground="#A855F7"
                                   PressedBackground="#C084FC"
                                   Click="Copy_Template_Click"
                                   Margin="0 6">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTaskAdd24" Margin="0,0,4,0"/>
                                <TextBlock Text="הסבר הסבה"/>
                            </StackPanel>
                        </ui:Button>
                        <!-- transfer_process_en -->
                        <ui:Button Appearance="Info"
                                   Background="#4F46E5"
                                   Tag="transfer_process_en"
                                   FontWeight="SemiBold"
                                   MouseOverBackground="#6366F1"
                                   PressedBackground="#818CF8"
                                   Click="Copy_Template_Click"
                                   Margin="0 6">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTaskAdd24" Margin="0,0,4,0"/>
                                <TextBlock Text="תהליך הסבה - אנ"/>
                            </StackPanel>
                        </ui:Button>

                        <!-- transport_fine_en -->
                        <ui:Button Appearance="Info"
                                   Background="#9333EA"
                                   Tag="transport_fine_en"
                                   FontWeight="SemiBold"
                                   MouseOverBackground="#A855F7"
                                   PressedBackground="#C084FC"
                                   Click="Copy_Template_Click"
                                   Margin="0 6">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTaskAdd24" Margin="0,0,4,0"/>
                                <TextBlock Text="הסבר נתיב תחב״צ - אנ"/>
                            </StackPanel>
                        </ui:Button>

                        <!-- appeal_fine -->
                        <ui:Button Appearance="Info"
                                   Background="#BE123C"
                                   Tag="appeal_fine"
                                   FontWeight="SemiBold"
                                   MouseOverBackground="#E11D48"
                                   PressedBackground="#FB7185"
                                   Click="Copy_Template_Click"
                                   Margin="0 6">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTaskAdd24" Margin="0,0,4,0"/>
                                <TextBlock Text="ערעור כחול לבן"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Info"
                                   Background="#BE123C"
                                   Tag="police_fine"
                                   FontWeight="SemiBold"
                                   MouseOverBackground="#E11D48"
                                   PressedBackground="#FB7185"
                                   Click="Copy_Dynamic_Click"
                                   Margin="0 6">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTaskAdd24" Margin="0,0,4,0"/>
                                <TextBlock Text="מייל דוח משטרה"/>
                            </StackPanel>
                        </ui:Button>
                        <ui:Button Appearance="Info"
                                   Background="#BE123C"
                                   Tag="municipal_fine"
                                   FontWeight="SemiBold"
                                   MouseOverBackground="#E11D48"
                                   PressedBackground="#FB7185"
                                   Click="Copy_Dynamic_Click"
                                   Margin="0 6">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="ClipboardTaskAdd24" Margin="0,0,4,0"/>
                                <TextBlock Text="מייל דוח פיקוח"/>
                            </StackPanel>
                        </ui:Button>
                    </UniformGrid>
                </Grid>
            </ui:Card>
            <controls:OverlayBanner x:Name="Overlay"
                                    Grid.Row="0"/>
        </Grid>
    </Border>
</Page>
